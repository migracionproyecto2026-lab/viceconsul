generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Citizen {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  nombre        String
  apellido      String
  email         String    @unique
  password      String?
  telefono      String?
  cedula        String?
  tipoDocumento String?
  esInvitado    Boolean   @default(false)
  verified      Boolean   @default(false)
  verifyCode    String?
  verifyExpiry  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  citas         Appointment[]
}

model AdminUser {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  nombre        String
  email         String    @unique
  password      String
  role          String    @default("asistente")
  cargo         String?
  permisos      String[]
  buzonLastRead DateTime?
  createdAt     DateTime  @default(now())
}

model Appointment {
  id                   String       @id @default(auto()) @map("_id") @db.ObjectId
  serial               String?      @unique
  citizenId            String?      @db.ObjectId
  citizen              Citizen?     @relation(fields: [citizenId], references: [id])
  nombreExterno        String?
  emailExterno         String?
  telefonoExterno      String?
  tipoDocumento        String?
  cedulaExterno        String?
  fecha                String?
  hora                 String
  tramite              String
  status               String       @default("pendiente")
  origen               String       @default("admin")  // 'web' | 'admin'
  notas                String?
  documentosPendientes String?
  recordatorioEnviado  Boolean      @default(false)
  valijaId             String?      @db.ObjectId
  valija               Valija?      @relation(fields: [valijaId], references: [id])
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  logs                 ActivityLog[]
}

model Valija {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  serial          String        @unique
  estado          String        @default("abierta")  // abierta | enviada | recibida
  fechaEnvio      DateTime?
  fechaRecepcion  DateTime?
  notaInterna     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  citas           Appointment[]
}

model Counter {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String @unique
  value Int    @default(0)
}

model ActivityLog {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  tipo             String
  citaId           String?      @db.ObjectId
  cita             Appointment? @relation(fields: [citaId], references: [id])
  ciudadanoEmail   String?
  mensajeCiudadano String?
  notaInterna      String?
  datos            String?
  realizadoPor     String
  // ── Auditoría extendida (reportería 360°) ──────────────────────────────
  realizadoPorId   String?      @db.ObjectId
  entidad          String?      // 'cita' | 'ciudadano' | 'usuario_admin' | 'banner' | 'valija' | 'fecha_bloqueada' | 'sesion' | 'reporte' | 'setting'
  entidadId        String?
  accion           String?      // 'crear' | 'editar' | 'eliminar' | 'cambio_estado' | 'login_ok' | 'login_fail' | 'logout' | 'cambio_permisos' | 'exportar'
  ip               String?
  userAgent        String?
  antes            String?      // JSON snapshot pre-cambio (sin password / verifyCode)
  despues          String?      // JSON snapshot post-cambio
  createdAt        DateTime     @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([entidad, createdAt(sort: Desc)])
  @@index([realizadoPorId, createdAt(sort: Desc)])
  @@index([ciudadanoEmail])
}

model SessionLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  adminUserId   String?  @db.ObjectId
  email         String
  nombre        String?
  role          String?
  tipo          String   // 'login_ok' | 'login_fail' | 'logout' | 'expirado'
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([email, createdAt(sort: Desc)])
  @@index([adminUserId, createdAt(sort: Desc)])
  @@index([tipo, createdAt(sort: Desc)])
}

model TramiteMaestro {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  codigo             String   @unique
  nombre             String
  categoria          String?
  descripcion        String?
  requisitos         String[]
  duracionEstimada   Int?     // minutos
  activo             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([activo, categoria])
}

model Banner {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  categoria String?
  titulo    String
  cuerpo    String
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())
}

model BlockedDate {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  fecha  String  @unique
  motivo String?
}

// Semanas hábiles habilitadas adicionalmente (más allá de la semana en curso
// y la siguiente). El identificador es la fecha del lunes (YYYY-MM-DD).
// Cuando una semana está en esta tabla, sus días L-V quedan disponibles
// (salvo que haya fechas individualmente bloqueadas en BlockedDate).
model SemanaHabilitada {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  lunes     String   @unique  // YYYY-MM-DD del lunes
  motivo    String?
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  clave String @unique
  valor String
}
