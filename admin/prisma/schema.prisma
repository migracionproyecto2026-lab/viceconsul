generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Citizen {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  nombre        String
  apellido      String
  email         String    @unique
  password      String?
  telefono      String?
  cedula        String?
  tipoDocumento String?
  esInvitado    Boolean   @default(false)
  verified      Boolean   @default(false)
  verifyCode    String?
  verifyExpiry  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  citas         Appointment[]
}

model AdminUser {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  nombre        String
  email         String    @unique
  password      String
  role          String    @default("asistente")
  buzonLastRead DateTime?
  createdAt     DateTime  @default(now())
}

model Appointment {
  id                   String       @id @default(auto()) @map("_id") @db.ObjectId
  citizenId            String?      @db.ObjectId
  citizen              Citizen?     @relation(fields: [citizenId], references: [id])
  nombreExterno        String?
  emailExterno         String?
  telefonoExterno      String?
  tipoDocumento        String?
  cedulaExterno        String?
  fecha                String?
  hora                 String
  tramite              String
  status               String       @default("pendiente")
  notas                String?
  documentosPendientes String?
  recordatorioEnviado  Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  logs                 ActivityLog[]
}

model ActivityLog {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  tipo             String
  citaId           String?      @db.ObjectId
  cita             Appointment? @relation(fields: [citaId], references: [id])
  ciudadanoEmail   String?
  mensajeCiudadano String?
  notaInterna      String?
  datos            String?
  realizadoPor     String
  createdAt        DateTime     @default(now())
}

model Banner {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  categoria String?
  titulo    String
  cuerpo    String
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())
}

model BlockedDate {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  fecha  String  @unique
  motivo String?
}

model Setting {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  clave String @unique
  valor String
}
